# ECC environment variables
ASPNETCORE_ENVIRONMENT=Development

# SQL Server connection
SECURITYDB_CONNECTION=Server=localhost;Database=ECC_SecurityDB;Trusted_Connection=True;TrustServerCertificate=True

# Azure Entra ID
AZUREAD_TENANT_ID=your-tenant-id
AZUREAD_CLIENT_ID=your-client-id
AZUREAD_AUDIENCE=api://your-client-id

# Frontend
VITE_ENTRA_CLIENT_ID=your-client-id
VITE_ENTRA_TENANT_ID=your-tenant-id
VITE_ENTRA_REDIRECT_URI=http://localhost:5173
