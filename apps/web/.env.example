# =============================================================
# ECC Local Environment Variables (Example)
# Copy to .env.development or .env.local and fill real values.
# Never commit real secrets.
# =============================================================

# -------------------------------------------------------------
# API - Runtime
# -------------------------------------------------------------
AUTH_MODE=Entra
DATA_MODE=Local

# -------------------------------------------------------------
# API - Microsoft Entra ID (maps to Entra:Authority / Entra:Audience)
# -------------------------------------------------------------
Entra__Authority=https://login.microsoftonline.com/your-tenant-id/v2.0
Entra__Audience=api://your-api-client-id

# -------------------------------------------------------------
# API - Azure SQL (maps to ConnectionStrings:Default)
# -------------------------------------------------------------
ConnectionStrings__Default=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=YourDatabase;Persist Security Info=False;User ID=your_db_user;Password=your_db_password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# -------------------------------------------------------------
# API - Optional JWT config
# -------------------------------------------------------------
SCC_JWT_ISSUER=https://scc.claas2saas.com
SCC_JWT_AUDIENCE=c2s-applications
SCC_JWT_EXPIRY_MINUTES=30

# -------------------------------------------------------------
# Frontend - Vite (must be prefixed with VITE_)
# -------------------------------------------------------------
VITE_AUTH_MODE=entra
VITE_API_URL=http://localhost:8000
VITE_ENTRA_CLIENT_ID=your-client-id-here
VITE_ENTRA_TENANT_ID=your-tenant-id-here
VITE_ENTRA_REDIRECT_URI=http://localhost:5173
VITE_ENTRA_API_SCOPE=api://your-api-client-id/access_as_user
VITE_TEST_TENANT_ID=demo-tenant-001


